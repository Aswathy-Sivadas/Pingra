# ─── backend/.env.example ────────────────────────────────────────────────────
# Copy this to backend/.env and fill in your values for local development.
# In production (Render), set these in the Render dashboard or via render.yaml.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/chatapp?retryWrites=true&w=majority

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here

# ── Frontend URL (for CORS) ───────────────────────────────────────────────────
# Local dev: Vite dev server
CLIENT_URL=http://localhost:5173

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=no-reply@yourdomain.com
EMAIL_FROM_NAME=ChatApp

# ── Cloudinary ────────────────────────────────────────────────────────────────
# Get from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Arcjet ────────────────────────────────────────────────────────────────────
# Get from: https://arcjet.com → Your site → API key
ARCJET_KEY=ajkey_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
ARCJET_ENV=development

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local: run `docker run -d -p 6379:6379 redis:7-alpine`
# Cloud: get URL from Render or https://redis.io/try-free
REDIS_URL=redis://127.0.0.1:6379
